# ============================================================
# 种子团队任务管理系统 — 生产环境变量
# 复制为 deploy/.env.prod 后修改所有 CHANGE_ME 值
# ============================================================

# --- Django ---
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_A_64_CHAR_RANDOM_STRING
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com
TIME_ZONE=Asia/Shanghai

# --- PostgreSQL ---
POSTGRES_DB=seedteam
POSTGRES_USER=seedteam
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- JWT ---
JWT_SIGNING_KEY=CHANGE_ME_GENERATE_ANOTHER_64_CHAR_RANDOM_STRING
JWT_ACCESS_TOKEN_LIFETIME=15
JWT_REFRESH_TOKEN_LIFETIME=7

# --- Email (SMTP) ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=CHANGE_ME_SMTP_PASSWORD
DEFAULT_FROM_EMAIL=种子团队任务系统 <noreply@yourdomain.com>

# --- Backup ---
RESTIC_PASSWORD=CHANGE_ME_RESTIC_ENCRYPTION_KEY
OSS_BUCKET=oss://your-backup-bucket
OSS_ACCESS_KEY_ID=CHANGE_ME
OSS_ACCESS_KEY_SECRET=CHANGE_ME
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# --- Monitoring ---
UPTIMEROBOT_API_KEY=CHANGE_ME_OPTIONAL
