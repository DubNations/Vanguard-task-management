# ============================================================
# 种子团队任务管理系统 — 开发环境变量
# 用于本地开发，不要提交到 Git
# ============================================================

DJANGO_ENV=dev
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
TIME_ZONE=Asia/Shanghai

# PostgreSQL (本地 Docker)
POSTGRES_DB=seedteam_dev
POSTGRES_USER=seedteam
POSTGRES_PASSWORD=seedteam_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
JWT_SIGNING_KEY=dev-jwt-signing-key-not-for-production
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=30

# Email (console backend in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
